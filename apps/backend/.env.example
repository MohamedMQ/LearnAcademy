# Database
DATABASE_URL=postgresql://learnacademy:learnacademy_secret@localhost:5432/learnacademy

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-at-least-32-chars-long-secret-key
JWT_EXPIRES_IN=7d

# Google AI (free tier - get key at https://aistudio.google.com)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Google OAuth (must match frontend provider client)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Billing mode: mock (free/dev), stripe (future)
BILLING_MODE=mock

# Upload
UPLOAD_DIR=./uploads

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
