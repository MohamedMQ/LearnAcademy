NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-at-least-32-chars-long-secret-key
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth v5 Google provider
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Set to true to show Google auth buttons in UI
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
